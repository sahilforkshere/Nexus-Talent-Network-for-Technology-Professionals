# Nexus — Environment Variables
# Copy this file to .env and fill in your values.
# Run: cp .env.example .env

# OpenAI (required for semantic job search)
OPENAI_API_KEY=sk-your-key-here

# PostgreSQL
DATABASE_URL=postgres://nexus:nexus@localhost:5432/nexus?sslmode=disable

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexuspassword

# Kafka
KAFKA_BROKER=localhost:9092

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Redis
REDIS_URL=redis://localhost:6379

# JWT (must be same across all services)
JWT_SECRET=nexus-dev-secret-change-in-production

# Service Ports
PROFILE_PORT=4001
NETWORK_PORT=4002
JOBS_PORT=4003
FEED_PORT=4004
